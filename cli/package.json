{
  "name": "@kaluchi/qlang-cli",
  "version": "0.8.1",
  "description": "Command-line interface and REPL for the qlang pipeline query language",
  "type": "module",
  "main": "src/main.mjs",
  "exports": {
    ".": {
      "import": "./src/main.mjs"
    },
    "./cli-locator": {
      "import": "./src/cli-locator.mjs"
    }
  },
  "bin": {
    "qlang": "src/bin.mjs",
    "ql": "src/bin.mjs"
  },
  "files": [
    "src/",
    "lib/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "qlang",
    "cli",
    "query-language",
    "json"
  ],
  "license": "Apache-2.0",
  "author": "kaluchi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaluchi/qlang.git"
  },
  "dependencies": {
    "@kaluchi/qlang-core": "*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.0.0"
  }
}
