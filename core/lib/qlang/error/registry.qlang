::AsNameNotKeywordError
  |~~ `as` requires a Keyword captured-arg (the binding name). ~~|
  {:qlang/kind :type}

::EvalSubjectNotMapOrQuoteError
  |~~ `eval` requires a Map (AST-Map) or Quote (source-form) subject. ~~|
  {:qlang/kind :type}

::ParseSubjectNotStringOrQuoteError
  |~~ `parse` requires a String or Quote subject. ~~|
  {:qlang/kind :type}

::ReifyKeyNotKeywordError
  |~~ `reify(:name)` requires a Keyword captured-arg (the binding name to look up). ~~|
  {:qlang/kind :type}

::RunExamplesSubjectShapeError
  |~~ `runExamples` requires a Keyword (binding name) or a descriptor Map carrying a `:name` String. ~~|
  {:qlang/kind :type}

::UseNameNotExportedError
  |~~ `use(:ns, #{:name1 вЂ¦})` вЂ” selection filter names an identifier the namespace does not export. ~~|
  {:qlang/kind :type}

::UseNamespaceCollisionError
  |~~ `use(#{:ns1 :ns2 вЂ¦})` вЂ” two namespaces export a name under the same identifier; Set-form rejects collisions. ~~|
  {:qlang/kind :type}

::UseNamespaceElementNotKeywordError
  |~~ `use([:ns1 :ns2 вЂ¦])` вЂ” every element of the namespace Vec must be a Keyword. ~~|
  {:qlang/kind :type}

::UseNamespaceNotFoundError
  |~~ `use(:ns)` вЂ” namespace not in env and no host-provided locator can resolve it. ~~|
  {:qlang/kind :type}

::UseNamespaceNotKeywordError
  |~~ `use(:ns)` requires a Keyword captured-arg naming the namespace to import. ~~|
  {:qlang/kind :type}

::UseNamespaceNotMapError
  |~~ `use(:ns)` вЂ” env binding under `:ns` is not a Map; cannot import as a namespace. ~~|
  {:qlang/kind :type}

::UseSubjectNotMapError
  |~~ `use` (bare form) requires a Map subject вЂ” its entries become the merged bindings. ~~|
  {:qlang/kind :type}

