{
  "name": "@kaluchi/qlang-core",
  "version": "0.6.0",
  "description": "Reference implementation of the qlang pipeline query language",
  "type": "module",
  "main": "src/index.mjs",
  "exports": {
    ".": {
      "import": "./src/index.mjs"
    },
    "./parse": {
      "import": "./src/parse.mjs"
    },
    "./eval": {
      "import": "./src/eval.mjs"
    },
    "./runtime": {
      "import": "./src/runtime/index.mjs"
    },
    "./walk": {
      "import": "./src/walk.mjs"
    },
    "./ast-codec": {
      "import": "./src/ast-codec.mjs"
    },
    "./session": {
      "import": "./src/session.mjs"
    },
    "./codec": {
      "import": "./src/codec.mjs"
    },
    "./errors": {
      "import": "./src/errors.mjs"
    },
    "./effect-check": {
      "import": "./src/effect-check.mjs"
    },
    "./dispatch": {
      "import": "./src/runtime/dispatch.mjs"
    },
    "./operand-errors": {
      "import": "./src/operand-errors.mjs"
    },
    "./highlight": {
      "import": "./src/highlight.mjs"
    },
    "./host/module-resolver": {
      "import": "./host/module-resolver.mjs"
    }
  },
  "imports": {
    "#qlang/core":                "./lib/qlang/core.qlang",
    "#qlang/runtime-invariants":  "./lib/qlang/runtime-invariants.qlang",
    "#qlang/tag":                 "./lib/qlang/tag.qlang",
    "#qlang/operand/arith":       "./lib/qlang/operand/arith.qlang",
    "#qlang/operand/vec":         "./lib/qlang/operand/vec.qlang",
    "#qlang/operand/container":   "./lib/qlang/operand/container.qlang",
    "#qlang/operand/set-op":      "./lib/qlang/operand/set-op.qlang",
    "#qlang/operand/map-op":      "./lib/qlang/operand/map-op.qlang",
    "#qlang/operand/string":           "./lib/qlang/operand/string.qlang",
    "#qlang/operand/comparator":       "./lib/qlang/operand/comparator.qlang",
    "#qlang/operand/predicate":        "./lib/qlang/operand/predicate.qlang",
    "#qlang/operand/type-classifier":  "./lib/qlang/operand/type-classifier.qlang",
    "#qlang/operand/type-conversion":  "./lib/qlang/operand/type-conversion.qlang",
    "#qlang/operand/control":          "./lib/qlang/operand/control.qlang",
    "#qlang/operand/format":           "./lib/qlang/operand/format.qlang",
    "#qlang/operand/reflective":       "./lib/qlang/operand/reflective.qlang",
    "#qlang/load-source": {
      "node": "./host/load-source-node.mjs",
      "default": "./src/load-source-web.mjs"
    }
  },
  "sideEffects": false,
  "files": [
    "src/",
    "host/",
    "lib/",
    "gen/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:grammar": "node scripts/build-grammar.mjs",
    "build": "node scripts/build-grammar.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "query-language",
    "interpreter",
    "pipeline"
  ],
  "license": "Apache-2.0",
  "author": "kaluchi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaluchi/qlang.git"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "peggy": "^4.2.0",
    "vitest": "^3.0.0"
  }
}
