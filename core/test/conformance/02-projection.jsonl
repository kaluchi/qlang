{"name":"single-key","query":"{:name \"Alice\"} | /name","expect":"\"Alice\""}
{"name":"missing-key","query":"{:name \"Alice\"} | /age","expect":"::ProjectionKeyNotInMapError!{\n  :faultStep ~{/age}\n  :faultInput {:name \"Alice\"}\n  :key \"age\"\n}"}
{"name":"nested-keys","query":"{:point {:x 5 :y 7}} | /point/x","expect":"5"}
{"name":"deeply-nested","query":"{:a {:b {:c {:d 42}}}} | /a/b/c/d","expect":"42"}
{"name":"projection-after-filter","query":"[{:name \"Alice\" :age 25} {:name \"Bob\" :age 17}] | filter(/age | gte(18)) * /name","expect":"[\"Alice\"]"}
{"name":"quoted-projection-single-key","query":"{:\"foo bar\" 42} | /\"foo bar\"","expect":"42"}
{"name":"quoted-projection-leading-digit","query":"{:\"123\" \"x\"} | /\"123\"","expect":"\"x\""}
{"name":"nested-quoted-projection","query":"{:\"a.b\" {:\"$ref\" 99}} | /\"a.b\"/\"$ref\"","expect":"99"}
{"name":"mixed-quoted-and-bare-projection","query":"{:outer {:\"inner key\" 7}} | /outer/\"inner key\"","expect":"7"}
{"name":"quoted-projection-empty-key","query":"{:\"\" 5} | /\"\"","expect":"5"}
{"name":"vec-bare-index-zero","query":"[10 20 30] | /0","expect":"10"}
{"name":"vec-bare-index-mid","query":"[10 20 30] | /1","expect":"20"}
{"name":"vec-bare-index-negative","query":"[10 20 30] | /-1","expect":"30"}
{"name":"vec-bare-index-oob","query":"[10 20 30] | /99","expect":"::ProjectionIndexOutOfBoundsError!{\n  :faultStep ~{/99}\n  :faultInput [10 20 30]\n  :key \"99\"\n  :index 99\n  :length 3\n}"}
{"name":"vec-bare-index-negative-oob","query":"[10 20 30] | /-99","expect":"::ProjectionIndexOutOfBoundsError!{\n  :faultStep ~{/-99}\n  :faultInput [10 20 30]\n  :key \"-99\"\n  :index -99\n  :length 3\n}"}
{"name":"vec-non-integer-segment-null","query":"[10 20 30] | /name","expect":"::ProjectionSequenceKeyNotIntegerError!{\n  :faultStep ~{/name}\n  :faultInput [10 20 30]\n  :key \"name\"\n}"}
{"name":"polymorphic-deep-path","query":"{\"items\": [{\"id\": 1} {\"id\": 2}]} | /items/0/id","expect":"1"}
{"name":"polymorphic-negative-through-vec","query":"{\"users\": [{\"email\": \"a@x\"} {\"email\": \"b@x\"}]} | /users/-1/email","expect":"\"b@x\""}
{"name":"polymorphic-vec-then-map","query":"[{\"name\": \"alice\"} {\"name\": \"bob\"}] | /1/name","expect":"\"bob\""}
{"name":"map-numeric-key-vs-vec-index","query":"{\"0\": [0 1]} | /0","expect":"[0 1]"}
{"name":"mixed-map-then-vec-bare-index","query":"{\"rows\": [[1 2] [3 4]]} | /rows/1/0","expect":"3"}
{"name":"null-subject-strict","query":"null | /any","expect":"::ProjectionSubjectNotProjectableError!{\n  :faultStep ~{/any}\n  :faultInput null\n  :actualType :null\n  :key \"any\"\n}"}
