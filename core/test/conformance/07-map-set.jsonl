{"name":"keys","query":"{:name \"Alice\" :age 30} | keys","expect":"#[:name :age]"}
{"name":"vals","query":"{:name \"Alice\" :age 30} | vals","expect":"[\"Alice\" 30]"}
{"name":"has-map-true","query":"{:name \"Alice\"} | has(:name)","expect":"true"}
{"name":"has-map-false","query":"{:name \"Alice\"} | has(:age)","expect":"false"}
{"name":"has-set-true","query":"#[:a :b :c] | has(:b)","expect":"true"}
{"name":"has-set-false","query":"#[:a :b :c] | has(:d)","expect":"false"}
{"name":"has-set-structural-vec-key-true","query":"#[[1 2] [3 4]] | has([1 2])","expect":"true"}
{"name":"has-set-structural-vec-key-false","query":"#[[1 2] [3 4]] | has([5 6])","expect":"false"}
{"name":"has-set-structural-map-key-true","query":"#[{:a 1} {:b 2}] | has({:a 1})","expect":"true"}
{"name":"has-set-structural-map-key-false","query":"#[{:a 1} {:b 2}] | has({:c 3})","expect":"false"}
{"name":"has-set-structural-nested-set-key","query":"#[#[:x :y] #[:z]] | has(#[:x :y])","expect":"true"}
{"name":"distinct-as-vec-to-set-converter","query":"[1 2 1 3 2] | distinct","expect":"#[1 2 3]"}
{"name":"set-literal","query":"#[1 2 3]","expect":"#[1 2 3]"}
{"name":"set-literal-with-projections","query":"{:name \"Alice\" :age 30} | #[/name, /age]","expect":"#[\"Alice\" 30]"}
{"name":"map-empty-keys","query":"{} | keys","expect":"#[]"}
{"name":"map-empty-vals","query":"{} | vals","expect":"[]"}
{"name":"distribute-over-set","query":"#[1 2 3] * add(1)","expect":"[2 3 4]"}
{"name":"distribute-over-set-insertion-order","query":"#[3 1 2] * add(1)","expect":"[4 2 3]"}
{"name":"distribute-over-set-degrades-to-vec","query":"#[1 2 3] * mul(0)","expect":"[0 0 0]"}
{"name":"distribute-over-set-redistinct","query":"#[1 2 3] * add(1) | distinct","expect":"#[2 3 4]"}
{"name":"merge-over-set","query":"#[[1 2] [3 4]] >> count","expect":"4"}
{"name":"merge-over-set-of-sets","query":"#[#[1 2] #[3 4]] >> count","expect":"4"}
{"name":"merge-vec-of-sets-flattens-inner-sets","query":"[#[1 2] #[3 4]] >> count","expect":"4"}
