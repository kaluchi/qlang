{"name":"scientific-integer-exp","query":"1e10","expect":"10000000000"}
{"name":"scientific-negative-exp","query":"2.5e-3","expect":"0.0025"}
{"name":"scientific-positive-exp-upper","query":"1.5E+6","expect":"1500000"}
