{"name":"scientific-negative-number","query":"-2.5e3","expect":"-2500"}
{"name":"scientific-zero-exponent","query":"1e0","expect":"1"}
{"name":"scientific-integer-no-frac","query":"2e3","expect":"2000"}
{"name":"scientific-upper-no-sign","query":"5E10","expect":"50000000000"}
{"name":"scientific-in-pipeline","query":"{\"rate\": 1.5e-2} | /rate","expect":"0.015"}
{"name":"json-reserved-key-null","query":"{\"null\": 42} | /null","expect":"42"}
{"name":"json-reserved-key-true","query":"{\"true\": 1} | /true","expect":"1"}
{"name":"json-reserved-key-false","query":"{\"false\": 0} | /false","expect":"0"}
{"name":"json-deep-nesting","query":"{\"a\": {\"b\": {\"c\": 42}}} | /a/b/c","expect":"42"}
{"name":"json-boolean-values","query":"{\"x\": true, \"y\": false} | [/x, /y]","expect":"[true false]"}
{"name":"json-null-value","query":"{\"x\": null} | /x","expect":"null"}
{"name":"json-array-value-sum","query":"{\"items\": [1, 2, 3]} | /items | sum","expect":"6"}
{"name":"json-numeric-string-key","query":"{\"42\": \"answer\"} | /\"42\"","expect":"\"answer\""}
{"name":"json-kebab-string-key","query":"{\"foo-bar\": 99} | /\"foo-bar\"","expect":"99"}
{"name":"json-full-roundtrip","query":"{\"name\": \"alice\", \"age\": 30, \"active\": true, \"score\": null} | [/name, /age, /active, /score]","expect":"[\"alice\" 30 true null]"}
