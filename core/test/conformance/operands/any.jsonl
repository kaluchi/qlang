{"name":"at-least-one-satisfies","query":"[1 2 3] | any(gt(2))","expect":"true"}
{"name":"none-satisfy","query":"[1 2 3] | any(gt(99))","expect":"false"}
{"name":"first-element-satisfies","query":"[5 1 2] | any(gt(2))","expect":"true"}
{"name":"vacuously-false-on-empty","query":"[] | any(gt(0))","expect":"false"}
{"name":"vacuously-false-on-empty-with-arbitrary-pred","query":"[] | any(eq(99))","expect":"false"}
{"name":"any-with-projection","query":"[{:active false} {:active true}] | any(/active)","expect":"true"}
{"name":"any-with-projection-none","query":"[{:active false} {:active false}] | any(/active)","expect":"false"}
{"name":"any-with-compound-pred","query":"[{:role :user} {:role :admin}] | any(/role | eq(:admin))","expect":"true"}
{"name":"any-on-non-container-throws","query":"42 | any(gt(0))","error":"type-error","expect":"!{:origin :qlang/eval :kind :type-error :thrown :AnySubjectNotContainer :message \"any requires Vec, Set, or Map subject, got Number\" :operand \"any\" :position \"subject\" :expectedType \"Vec, Set, or Map\" :actualType \"Number\"}"}
{"name":"any-short-circuits","query":"[1 2 99] | any(gt(50))","expect":"true"}
{"name":"any-as-filter-equivalence","query":"[1 2 3] | filter(gt(2)) | empty | not | eq([1 2 3] | any(gt(2)))","expect":"true"}
{"name":"any-string-predicate-integration","query":"[\"alice\" \"bob\" \"alex\"] | any(startsWith(\"al\"))","expect":"true"}
{"name":"any-set-one-matches","query":"#{1 2 3} | any(gt(2))","expect":"true"}
{"name":"any-set-none-match","query":"#{1 2 3} | any(gt(99))","expect":"false"}
{"name":"any-map-value-matches","query":"{:a -1 :b 0 :c 2} | any(byValue(gt(0)))","expect":"true"}
{"name":"any-map-no-value-matches","query":"{:a -1 :b -2 :c -3} | any(byValue(gt(0)))","expect":"false"}
{"name":"any-map-empty-vacuous","query":"{} | any(byValue(gt(0)))","expect":"false"}
{"name":"any-map-by-key-pattern","query":"{:apple 1 :banana 2} | any(byKey(kwName | startsWith(\"a\")))","expect":"true"}
