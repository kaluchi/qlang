{"name":"at-on-map-via-vals","query":"{:a 10 :b 20 :c 30} | vals | at(1)","expect":"20"}
{"name":"at-index-not-integer-error","query":"[1 2 3] | at(0.5)","error":"type-error","expect":"!{:origin :qlang/eval :kind :type-error :thrown :AtIndexNotInteger :message \"at expects Integer at position 2, got Number\" :operand \"at\" :position 2 :expectedType \"Integer\" :actualType \"Number\"}"}
