{"name":"at-positive-index","query":"[10 20 30] | at(0)","expect":"10"}
{"name":"at-mid-index","query":"[10 20 30] | at(1)","expect":"20"}
{"name":"at-last-via-positive","query":"[10 20 30] | at(2)","expect":"30"}
{"name":"at-negative-last","query":"[10 20 30] | at(-1)","expect":"30"}
{"name":"at-negative-second-last","query":"[10 20 30] | at(-2)","expect":"20"}
{"name":"at-negative-first","query":"[10 20 30] | at(-3)","expect":"10"}
{"name":"at-negative-equivalent-to-last","query":"[10 20 30] | at(-1) | eq([10 20 30] | last)","expect":"true"}
{"name":"at-out-of-range-positive","query":"[10 20 30] | at(99)","expect":"null"}
{"name":"at-out-of-range-negative","query":"[10 20 30] | at(-99)","expect":"null"}
{"name":"at-on-empty","query":"[] | at(0)","expect":"null"}
{"name":"at-preserves-element-type","query":"[{:id 1} {:id 2}] | at(0)","expect":"{:id 1}"}
{"name":"at-chained-with-projection","query":"[{:name \"alice\"} {:name \"bob\"}] | at(1) | /name","expect":"\"bob\""}
{"name":"at-subject-not-vec-or-map-error","query":"42 | at(0)","error":"type-error","expect":"!{\n  :origin :qlang/eval\n  :kind :type-error\n  :thrown :AtSubjectNotVecOrMap\n  :message \"at requires Vec or Map subject, got number\"\n  :operand \"at\"\n  :position \"subject\"\n  :expectedType \"Vec or Map\"\n  :actualType :number\n  :actualValue 42\n  :fault {:step `at(0)` :input 42}\n  :trail null\n}"}
{"name":"at-on-map-via-vals","query":"{:a 10 :b 20 :c 30} | vals | at(1)","expect":"20"}
{"name":"at-index-not-integer-error","query":"[1 2 3] | at(0.5)","error":"type-error","expect":"!{\n  :origin :qlang/eval\n  :kind :type-error\n  :thrown :AtIndexNotInteger\n  :message \"at expects Integer at position 2, got number\"\n  :operand \"at\"\n  :position 2\n  :expectedType \"Integer\"\n  :actualType :number\n  :actualValue 0.5\n  :fault {\n    :step `at(0.5)`\n    :input [1 2 3]\n  }\n  :trail null\n}"}
{"name":"at-map-string-key","query":"{:a 1 :b 2 :c 3} | at(\"b\")","expect":"2"}
{"name":"at-map-missing-key","query":"{:a 1} | at(\"z\")","expect":"null"}
{"name":"at-map-dynamic-key","query":"{:x 42} | as(:m) | \"x\" | as(:k) | m | at(k)","expect":"42"}
{"name":"at-map-quoted-key","query":"{:\"$ref\" 99} | at(\"$ref\")","expect":"99"}
{"name":"at-map-non-string-key-errors","query":"{:a 1} | at(42) !| /thrown","expect":":AtKeyNotString"}
