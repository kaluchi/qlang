{"name":"empty-vec-is-non-null","query":"{:list []} | coalesce(/missing, /list, \"default\")","expect":"[]"}
{"name":"empty-map-is-non-null","query":"{:obj {}} | coalesce(/missing, /obj, \"default\")","expect":"{}"}
