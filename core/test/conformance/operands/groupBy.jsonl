{"name":"single-key-single-bucket","query":"[{:dept :eng :name \"a\"}] | groupBy(/dept) | /eng | first | /name","expect":"\"a\""}
{"name":"two-keys-two-buckets","query":"[{:dept :eng :name \"a\"} {:dept :sales :name \"b\"}] | groupBy(/dept) | keys | count","expect":"2"}
{"name":"multi-element-bucket-preserves-order","query":"[{:dept :eng :name \"a\"} {:dept :sales :name \"b\"} {:dept :eng :name \"c\"}] | groupBy(/dept) | /eng * /name","expect":"[\"a\" \"c\"]"}
{"name":"groupBy-by-derived-key","query":"[1 2 3 4 5] | groupBy(if(gt(2), :big, :small)) | /small","expect":"[1 2]"}
{"name":"groupBy-by-derived-key-big-bucket","query":"[1 2 3 4 5] | groupBy(if(gt(2), :big, :small)) | /big","expect":"[3 4 5]"}
{"name":"groupBy-empty-vec-yields-empty-map","query":"[] | groupBy(/k) | empty","expect":"true"}
{"name":"groupBy-non-vec-throws","query":"42 | groupBy(/k)","error":"typeError","expect":"::GroupBySubjectNotSequenceError!{\n  :faultStep ~{groupBy(/k)}\n  :faultInput 42\n  :actualType :number\n}"}
{"name":"groupBy-non-keyword-key-throws","query":"[{:k 1} {:k 2}] | groupBy(/k)","error":"typeError","expect":"::GroupByKeyNotKeywordError!{\n  :faultStep ~{groupBy(/k)}\n  :faultInput [{:k 1} {:k 2}]\n  :actualValue 1\n  :actualType :number\n  :index 0\n}"}
{"name":"groupBy-then-distribute-count","query":"[{:c :a} {:c :b} {:c :a} {:c :a}] | groupBy(/c) | vals * count","expect":"[3 1]"}
{"name":"groupBy-roundtrip-via-vals-flat","query":":xs [{:k :a} {:k :b} {:k :a}] | xs | groupBy(/k) | vals | flat | count | eq(xs | count)","expect":"true"}
{"name":"groupBy-jsonarray-subject-preserves-bucket-jsonarray-tag","query":"::json[1 2 3 4 5] | groupBy(if(gt(2), :big, :small)) | /big | type","expect":":jsonArray"}
{"name":"groupBy-jsonarray-subject-small-bucket-also-jsonarray","query":"::json[1 2 3 4 5] | groupBy(if(gt(2), :big, :small)) | /small | type","expect":":jsonArray"}
{"name":"groupBy-vec-subject-bucket-stays-vec","query":"[1 2 3 4 5] | groupBy(if(gt(2), :big, :small)) | /big | type","expect":":vec"}
