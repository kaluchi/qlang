{"name":"single-element-single-key","query":"[{:id :a :name \"alice\"}] | indexBy(/id) | /a/name","expect":"\"alice\""}
{"name":"unique-keys-form-a-lookup-map","query":"[{:id :a :name \"alice\"} {:id :b :name \"bob\"}] | indexBy(/id) | /b/name","expect":"\"bob\""}
{"name":"duplicate-keys-last-wins","query":"[{:id :a :v 1} {:id :a :v 2}] | indexBy(/id) | /a/v","expect":"2"}
{"name":"indexBy-empty-vec-yields-empty-map","query":"[] | indexBy(/k) | empty","expect":"true"}
{"name":"indexBy-non-vec-throws","query":"42 | indexBy(/k)","error":"type-error","expect":"::IndexBySubjectNotSequenceError!{\n  :faultStep ~{indexBy(/k)}\n  :faultInput 42\n  :actualType :number\n}"}
{"name":"indexBy-non-keyword-key-throws","query":"[{:k 1}] | indexBy(/k)","error":"type-error","expect":"::IndexByKeyNotKeywordError!{\n  :faultStep ~{indexBy(/k)}\n  :faultInput [{:k 1}]\n  :actualValue 1\n  :actualType :number\n  :index 0\n}"}
{"name":"indexBy-then-projection-chain","query":"[{:id :u1 :role :admin} {:id :u2 :role :user}] | indexBy(/id) | /u1/role","expect":":admin"}
{"name":"indexBy-keys-set","query":"[{:id :a} {:id :b} {:id :c}] | indexBy(/id) | keys | count","expect":"3"}
