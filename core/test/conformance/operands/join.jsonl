{"name":"join-error-string-subject","query":"\"abc\" | join(\",\")","error":"type-error","expect":"!{:origin :qlang/eval :kind :type-error :thrown :JoinSubjectNotVec :message \"join requires Vec of Strings subject, got String\" :operand \"join\" :position \"subject\" :expectedType \"Vec of Strings\" :actualType \"String\"}"}
{"name":"join-error-set-subject","query":"#{1 2 3} | join(\",\")","error":"type-error","expect":"!{:origin :qlang/eval :kind :type-error :thrown :JoinSubjectNotVec :message \"join requires Vec of Strings subject, got Set\" :operand \"join\" :position \"subject\" :expectedType \"Vec of Strings\" :actualType \"Set\"}"}
{"name":"join-error-map-subject","query":"{:a 1} | join(\",\")","error":"type-error","expect":"!{:origin :qlang/eval :kind :type-error :thrown :JoinSubjectNotVec :message \"join requires Vec of Strings subject, got Map\" :operand \"join\" :position \"subject\" :expectedType \"Vec of Strings\" :actualType \"Map\"}"}
{"name":"join-error-element-not-string","query":"[\"a\" 42 \"c\"] | join(\",\")","error":"type-error","expect":"!{:origin :qlang/eval :kind :type-error :thrown :JoinElementNotString :message \"join: element 1 expects String, got Number\" :operand \"join\" :index 1 :expectedType \"String\" :actualType \"Number\"}"}
{"name":"join-error-element-null","query":"[\"a\" null \"c\"] | join(\",\")","error":"type-error","expect":"!{:origin :qlang/eval :kind :type-error :thrown :JoinElementNotString :message \"join: element 1 expects String, got Null\" :operand \"join\" :index 1 :expectedType \"String\" :actualType \"Null\"}"}
{"name":"join-error-element-vec","query":"[\"a\" [1] \"c\"] | join(\",\")","error":"type-error","expect":"!{:origin :qlang/eval :kind :type-error :thrown :JoinElementNotString :message \"join: element 1 expects String, got Vec\" :operand \"join\" :index 1 :expectedType \"String\" :actualType \"Vec\"}"}
