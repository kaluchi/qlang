{"name":"comma-separator","query":"[\"a\" \"b\" \"c\"] | join(\",\")","expect":"\"a,b,c\""}
{"name":"newline-separator","query":"[\"line1\" \"line2\" \"line3\"] | join(\"\\n\")","expect":"\"line1\\nline2\\nline3\""}
{"name":"semicolon-separator","query":"[\"x\" \"y\" \"z\"] | join(\";\")","expect":"\"x;y;z\""}
{"name":"space-separator","query":"[\"hello\" \"world\"] | join(\" \")","expect":"\"hello world\""}
{"name":"empty-separator-concatenates","query":"[\"x\" \"y\" \"z\"] | join(\"\")","expect":"\"xyz\""}
{"name":"multi-char-separator-double-colon","query":"[\"a\" \"b\" \"c\"] | join(\"::\")","expect":"\"a::b::c\""}
{"name":"multi-char-separator-arrow","query":"[\"a\" \"b\" \"c\"] | join(\" -> \")","expect":"\"a -> b -> c\""}
{"name":"empty-vec-yields-empty-string","query":"[] | join(\",\")","expect":"\"\""}
{"name":"empty-vec-with-empty-separator","query":"[] | join(\"\")","expect":"\"\""}
{"name":"singleton-vec","query":"[\"only\"] | join(\",\")","expect":"\"only\""}
{"name":"singleton-vec-empty-string","query":"[\"\"] | join(\",\")","expect":"\"\""}
{"name":"vec-with-empty-strings","query":"[\"\" \"\" \"\"] | join(\",\")","expect":"\",,\""}
{"name":"vec-with-empty-and-non-empty","query":"[\"a\" \"\" \"b\"] | join(\",\")","expect":"\"a,,b\""}
{"name":"two-elements","query":"[\"first\" \"second\"] | join(\" \")","expect":"\"first second\""}
{"name":"many-elements","query":"[\"a\" \"b\" \"c\" \"d\" \"e\" \"f\" \"g\" \"h\" \"i\" \"j\"] | join(\"\")","expect":"\"abcdefghij\""}
{"name":"join-after-split-roundtrip","query":"[\"a\" \"b\" \"c\"] | join(\",\") | split(\",\")","expect":"[\"a\" \"b\" \"c\"]"}
{"name":"join-after-distinct","query":"[\"a\" \"b\" \"a\" \"c\"] | distinct | join(\",\")","expect":"\"a,b,c\""}
{"name":"join-after-filter","query":"[\"\" \"a\" \"\" \"b\"] | filter(eq(\"\") | not) | join(\",\")","expect":"\"a,b\""}
{"name":"join-after-sort","query":"[\"c\" \"a\" \"b\"] | sort | join(\",\")","expect":"\"a,b,c\""}
{"name":"join-after-take","query":"[\"a\" \"b\" \"c\" \"d\"] | take(2) | join(\",\")","expect":"\"a,b\""}
{"name":"join-after-reverse","query":"[\"a\" \"b\" \"c\"] | reverse | join(\",\")","expect":"\"c,b,a\""}
{"name":"join-after-distribute","query":"[\"a\" \"b\" \"c\"] * append(\"!\") | join(\",\")","expect":"\"a!,b!,c!\""}
