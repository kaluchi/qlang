{"name":"reverse-jsonarray-preserves-tag","query":"::json[1 2 3] | reverse | type","expect":":jsonArray"}
{"name":"flat-jsonarray-preserves-tag","query":"::json[[1] [2 3]] | flat | type","expect":":jsonArray"}
{"name":"sortWith-jsonarray-preserves-tag","query":"::json[3 1 2] | sortWith(sub(/left, /right)) | type","expect":":jsonArray"}
