{"name":"parse-number-literal-kind","query":"\"42\" | parse | /:qlang/kind","expect":":NumberLit"}
{"name":"parse-number-literal-value","query":"\"42\" | parse | /value","expect":"42"}
{"name":"parse-string-literal-kind","query":"\"\\\"hello\\\"\" | parse | /:qlang/kind","expect":":StringLit"}
{"name":"parse-string-literal-value","query":"\"\\\"hello\\\"\" | parse | /value","expect":"\"hello\""}
{"name":"parse-keyword-literal-name","query":"\":foo\" | parse | /name","expect":"\"foo\""}
{"name":"parse-operand-call-name","query":"\"add(1, 2)\" | parse | /name","expect":"\"add\""}
{"name":"parse-operand-call-args-count","query":"\"add(1, 2)\" | parse | /args | count","expect":"2"}
{"name":"parse-bare-operand-args-null","query":"\"count\" | parse | /args","expect":"null"}
{"name":"parse-projection-keys","query":"\"/a/b/c\" | parse | /keys","expect":"[\"a\" \"b\" \"c\"]"}
{"name":"parse-pipeline-kind","query":"\"42 | add(1)\" | parse | /:qlang/kind","expect":":Pipeline"}
{"name":"parse-pipeline-step-count","query":"\"42 | add(1) | mul(2)\" | parse | /steps | count","expect":"3"}
{"name":"parse-non-string-subject","query":"42 | parse","expect":"!{:origin :qlang/eval :kind :type-error :thrown :ParseSubjectNotString :message \"parse requires String subject, got Number\" :operand \"parse\" :position \"subject\" :expectedType \"String\" :actualType \"Number\"}"}
{"name":"parse-malformed-source-kind","query":"\"this is bad [\" | parse !| /kind","expect":":parse-error"}
{"name":"parse-malformed-source-origin","query":"\"this is bad [\" | parse !| /origin","expect":":qlang/parse"}
{"name":"parse-malformed-source-thrown","query":"\"this is bad [\" | parse !| /thrown","expect":":ParseError"}
