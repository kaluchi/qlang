{"name":"parse-number-literal-kind","query":"\"42\" | parse | /:kind","expect":":NumberLit"}
{"name":"parse-number-literal-value","query":"\"42\" | parse | /value","expect":"42"}
{"name":"parse-string-literal-kind","query":"\"\\\"hello\\\"\" | parse | /:kind","expect":":StringLit"}
{"name":"parse-string-literal-value","query":"\"\\\"hello\\\"\" | parse | /value","expect":"\"hello\""}
{"name":"parse-keyword-literal-name","query":"\":foo\" | parse | /name","expect":"\"foo\""}
{"name":"parse-operand-call-name","query":"\"add(1, 2)\" | parse | /name","expect":"\"add\""}
{"name":"parse-operand-call-args-count","query":"\"add(1, 2)\" | parse | /args | count","expect":"2"}
{"name":"parse-bare-operand-args-null","query":"\"count\" | parse | /args","expect":"null"}
{"name":"parse-projection-keys","query":"\"/a/b/c\" | parse | /keys","expect":"[\"a\" \"b\" \"c\"]"}
{"name":"parse-pipeline-kind","query":"\"42 | add(1)\" | parse | /:kind","expect":":Pipeline"}
{"name":"parse-pipeline-step-count","query":"\"42 | add(1) | mul(2)\" | parse | /steps | count","expect":"3"}
{"name":"parse-non-string-subject","query":"42 | parse","expect":"::ParseSubjectNotStringOrQuoteError!{\n  :faultStep ~{parse}\n  :faultInput 42\n  :actualType :number\n}"}
{"name":"parse-quote-subject-kind","query":"~{5 | mul(2)} | parse | /:kind","expect":":Pipeline"}
{"name":"parse-malformed-source-category","query":"\"this is bad [\" | parse !| type | spec | /category","expect":":parseError"}
{"name":"parse-malformed-source-thrown","query":"\"this is bad [\" | parse !| type","expect":"::ParseError"}
