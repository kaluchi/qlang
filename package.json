{
  "name": "qlang-monorepo",
  "private": true,
  "description": "qlang language core and tooling workspaces",
  "type": "module",
  "workspaces": [
    "core",
    "cli",
    "lsp",
    "site",
    "vscode"
  ],
  "scripts": {
    "build": "npm run build -w @kaluchi/qlang-core",
    "build:site": "npm run build -w @kaluchi/qlang-site",
    "test": "npm test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "lint": "eslint .",
    "check:conventions": "node scripts/check-conventions.mjs",
    "ci": "npm run build && npm run lint && npm run check:conventions && npm test && npm run test:coverage && npm run test:integration && npm run build:site"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "author": "kaluchi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaluchi/qlang.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0"
  }
}
