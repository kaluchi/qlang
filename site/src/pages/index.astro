---
import Base from "../layouts/Base.astro"
import { parse, walkAst, langRuntime } from "../../../src/index.mjs"
import { highlightQlang } from "../lib/qlang-highlight.js"

const builtins = new Set([...langRuntime().keys()].map(k => k.name))

const examples = [
  {
    tab: "pipeline",
    file: "filter + count",
    code: `|~| Vec → filter → count\n> [1 2 3 4 5] | filter(gt(3)) | count\n2`,
  },
  {
    tab: "let",
    file: "let + distribute",
    code: `|~| bind name · spread over Vec\n> let(:double, mul(2)) | [10 20 30] * double\n[20 40 60]`,
  },
  {
    tab: "conduit",
    file: "parametric conduit",
    code: `|~| parametric conduit · @-effectful binding\n> let(:@surround, [:pfx, :sfx], prepend(pfx) | append(sfx))\n  | "world" | @surround("[", "]")\n"[world]"`,
  },
  {
    tab: "code-as-data",
    file: "parse | eval",
    code: `|~| source → AST-Map → pipeValue\n> "10 | add(3)" | parse | eval\n13`,
  },
]

function formatExample(code: string): string {
  const lines = code.split('\n');

  // Collect prompt + continuation lines for a single parse job.
  type LineInfo = { type: 'comment' | 'prompt' | 'cont' | 'result'; content: string };
  const infos: LineInfo[] = lines.map(line => {
    if (/^\|~/.test(line))       return { type: 'comment', content: line };
    if (line.startsWith('> '))   return { type: 'prompt',  content: line.slice(2) };
    if (/^  \S/.test(line))      return { type: 'cont',    content: line.slice(2) };
    return { type: 'result', content: line };
  });

  // Build combined qlang source from prompt/cont lines and highlight it.
  const codeLines = infos.filter(l => l.type === 'prompt' || l.type === 'cont');
  const combined  = codeLines.map(l => l.content).join('\n');
  const hlSplit   = highlightQlang(combined, parse, walkAst, builtins).split('\n');

  let codeIdx = 0;
  return infos.map(({ type, content }) => {
    if (type === 'comment') return `<span class="comment">${content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</span>`;
    if (type === 'prompt')  return `<span class="punct">&gt; </span>${hlSplit[codeIdx++] ?? ''}`;
    if (type === 'cont')    return `  ${hlSplit[codeIdx++] ?? ''}`;
    return highlightQlang(content, parse, walkAst, builtins);
  }).join('\n');
}

const features = [
  { title: "Pipeline composition", desc: "Thread values through chains of operands with |, distribute with *, merge with >>." },
  { title: "Immutable value types", desc: "Scalar, Vec, Map, Set, Error — all frozen. No mutation, no surprises." },
  { title: "Two-track error model", desc: "Success-track | deflects on errors, fail-track !| fires. Trail accumulates deflected steps as data." },
  { title: "Code as data", desc: "parse lifts source to an AST-Map, eval re-enters the evaluator. The ring closes." },
  { title: "Conduits", desc: "let binds named pipeline fragments with parameters. Lexical scope, recursive self-reference, zero-arity aliases." },
  { title: "Effect markers", desc: "@-prefixed identifiers carry side effects visibly. The runtime enforces propagation — no laundering." },
]
---

<Base title="qlang — pipeline expression language">
  <main class="landing">
    <div class="landing-container">
      <!-- Header -->
      <header class="landing-header">
        <a href={import.meta.env.BASE_URL} class="landing-logo">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <rect width="24" height="24" rx="4" fill="currentColor"/>
            <text x="12" y="17" text-anchor="middle" font-family="monospace" font-size="14" font-weight="bold" fill="hsl(0, 20%, 99%)">q</text>
          </svg>
          qlang
        </a>
        <nav class="landing-nav">
          <a href={`${import.meta.env.BASE_URL}/playground`}>Playground</a>
          <a href="https://github.com/kaluchi/qlang/blob/master/docs/qlang-spec.md" target="_blank" rel="noopener noreferrer">Docs</a>
          <a href="https://github.com/kaluchi/qlang" target="_blank" rel="noopener noreferrer">GitHub</a>
        </nav>
      </header>

      <div class="landing-content">
        <!-- Hero -->
        <section class="hero">
          <h1>Transform values through pipelines</h1>
          <p class="hero-subtitle">
            Expression language for composing immutable data transformations.
            Domain-agnostic. Pure. Runs in the browser.
          </p>
          <div class="install-section">
            <button class="install-command" id="install-btn" data-command="npm install @kaluchi/qlang">
              <code><span class="cmd">npm install </span><span class="highlight">@kaluchi/qlang</span></code>
              <span class="copy-btn">
                <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M8.75 8.75V2.75H21.25V15.25H15.25M15.25 8.75H2.75V21.25H15.25V8.75Z" stroke-linecap="square"/>
                </svg>
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2.75 15.0938L9 20.25L21.25 3.75" stroke-linecap="square"/>
                </svg>
              </span>
            </button>
          </div>
        </section>

        <!-- Code examples -->
        <section class="code-section">
          <div class="code-editor">
            <div class="code-editor-header">
              <div class="code-editor-dots">
                <span></span><span></span><span></span>
              </div>
              <div class="code-editor-tabs" role="tablist">
                {examples.map((ex, i) => (
                  <button
                    role="tab"
                    class="code-editor-tab"
                    data-tab={ex.tab}
                    aria-selected={i === 0 ? "true" : "false"}
                  >
                    {ex.file}
                  </button>
                ))}
              </div>
            </div>
            <div class="code-editor-panels">
              {examples.map((ex, i) => (
                <div class="code-editor-body" data-panel={ex.tab} data-active={i === 0 ? "true" : "false"}>
                  <pre><code set:html={formatExample(ex.code)} /></pre>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- Features -->
        <section class="features-section">
          <h2>What is qlang?</h2>
          <p>
            A pure expression language for transforming immutable values through
            pipelines. 69 built-in operands, five value types, two-track error
            model, parametric conduits, live REPL in the browser.
          </p>
          <div class="features-grid">
            {features.map(f => (
              <div class="feature-card">
                <h3>{f.title}</h3>
                <p>{f.desc}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- REPL -->
        <section class="repl-section">
          <h2>Try it</h2>
          <p>Type a qlang expression and press Enter. The evaluator runs entirely in your browser.</p>
          <div class="repl-container">
            <div class="repl-history" id="repl-history"></div>
            <div class="repl-input-area">
              <span class="repl-prompt">&gt;</span>
              <div class="repl-input-wrap">
                <pre class="repl-input-highlight" id="repl-highlight" aria-hidden="true"></pre>
                <textarea
                  class="repl-input"
                  id="repl-input"
                  rows="1"
                  placeholder={`[1 2 3 4 5] | filter(gt(2)) | count`}
                  spellcheck="false"
                  autocomplete="off"
                ></textarea>
              </div>
            </div>
          </div>
        </section>

        <!-- Footer -->
        <footer class="landing-footer">
          <a href="https://github.com/kaluchi/qlang" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href={`${import.meta.env.BASE_URL}/playground`}>Playground</a>
          <a href="https://www.npmjs.com/package/@kaluchi/qlang" target="_blank" rel="noopener noreferrer">npm</a>
        </footer>
      </div>
    </div>
    <div class="landing-legal">
      <span>&copy; 2026 <a href="https://github.com/kaluchi">kaluchi</a></span>
    </div>
  </main>
</Base>

<script>
  // ── Code editor tab switching ──────────────────────────
  const editorTabs = document.querySelectorAll('.code-editor-tab');
  const editorPanels = document.querySelectorAll('.code-editor-body');

  editorTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const tabId = tab.getAttribute('data-tab');
      editorTabs.forEach(t => t.setAttribute('aria-selected', 'false'));
      tab.setAttribute('aria-selected', 'true');
      editorPanels.forEach(panel => {
        panel.setAttribute('data-active', panel.getAttribute('data-panel') === tabId ? 'true' : 'false');
      });
    });
  });

  // ── Install copy ───────────────────────────────────────
  const installBtn = document.getElementById('install-btn');
  installBtn?.addEventListener('click', async () => {
    const cmd = installBtn.getAttribute('data-command');
    if (cmd) await navigator.clipboard.writeText(cmd);
    const copyBtn = installBtn.querySelector('.copy-btn');
    if (copyBtn) {
      copyBtn.classList.add('copied');
      setTimeout(() => copyBtn.classList.remove('copied'), 1500);
    }
  });

  // ── REPL ───────────────────────────────────────────────
  import { highlightQlang as hl } from '../lib/qlang-highlight.js';

  async function initRepl() {
    const { evalQuery, printValue, parse, walkAst, langRuntime } = await import(
      /* @vite-ignore */
      `${import.meta.env.BASE_URL}/qlang.js`
    );
    const builtins = new Set([...langRuntime().keys()].map((k: any) => k.name));
    const hi  = (src: string) => hl(src, parse, walkAst, builtins);
    const hiv = (src: string) => hl(printValue(evalQuery(src)), parse, walkAst, builtins);

    const input = document.getElementById('repl-input') as HTMLTextAreaElement;
    const history = document.getElementById('repl-history')!;

    function makeEntry(src: string, result: any) {
      const entry = document.createElement('div');
      entry.className = 'repl-entry';
      entry.innerHTML = `
        <div class="repl-entry-input"><span class="punct">&gt; </span>${hi(src)}</div>
        <div class="repl-entry-output">${hl(printValue(result), parse, walkAst, builtins)}</div>
      `;
      return entry;
    }

    // Pre-populate with example results
    const demos = [
      '[1 2 3 4 5] | filter(gt(2)) | count',
      '"hello" | append(" world") | prepend(">>> ")',
      `{
    "glossary": {
        "title": "example glossary",
        "GlossDiv": {
            "title": "S",
            "GlossList": {
                "GlossEntry": {
                    "ID": "SGML",
                    "SortAs": "SGML",
                    "GlossTerm": "Standard Generalized Markup Language",
                    "Acronym": "SGML",
                    "Abbrev": "ISO 8879:1986",
                    "GlossDef": {
                        "para": "A meta-markup language, used to create markup languages such as DocBook.",
                        "GlossSeeAlso": ["GML", "XML"]
                    },
                    "GlossSee": "markup"
                }
            }
        }
    }
} | /glossary/title`,
      '{:name "alice" :age 30} | /age | mul(2)',
    ];
    for (const src of demos) {
      history.appendChild(makeEntry(src, evalQuery(src)));
    }

    const replHighlight = document.getElementById('repl-highlight')!;
    function updateReplHighlight() {
      input.style.height = 'auto';
      input.style.height = input.scrollHeight + 'px';
      replHighlight.innerHTML = hi(input.value) + '\n';
      replHighlight.style.height = input.style.height;
    }
    input.addEventListener('input', updateReplHighlight);

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        const source = input.value.trim();
        if (!source) return;
        history.appendChild(makeEntry(source, evalQuery(source)));
        history.scrollTop = history.scrollHeight;
        input.value = '';
        updateReplHighlight();
      }
    });
  }

  initRepl();
</script>

