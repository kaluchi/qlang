{"name": "as-simple", "query": "42 | as answer | answer", "expect": 42}
{"name": "as-then-other-step", "query": "[1 2 3] | as nums | nums | count", "expect": 3}
{"name": "multi-stage-as", "query": "[85 92 47 78 68 95 52] | as allScores | filter(gte(70)) | as passingScores | [allScores | count, passingScores | count]", "expect": [7, 4]}
{"name": "let-double", "query": "let double = mul(2) | 10 | double", "expect": 20}
{"name": "let-then-distribute", "query": "let plus10 = add(10) | [1 2 3] * plus10", "expect": [11, 12, 13]}
{"name": "use-constants", "query": "{:taxRate 0.1 :base 100} | use | base | mul(taxRate)", "expect": 10}
