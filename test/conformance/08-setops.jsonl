{"name": "set-union", "query": "#{:a :b :c} | union(#{:b :d})", "expect": {"$set": [{"$keyword": "a"}, {"$keyword": "b"}, {"$keyword": "c"}, {"$keyword": "d"}]}}
{"name": "set-minus", "query": "#{:a :b :c} | minus(#{:b :d})", "expect": {"$set": [{"$keyword": "a"}, {"$keyword": "c"}]}}
{"name": "set-inter", "query": "#{:a :b :c} | inter(#{:b :d})", "expect": {"$set": [{"$keyword": "b"}]}}
{"name": "map-union-bound", "query": "{:name \"Alice\"} | union({:age 30})", "expect": {"$map": [[{"$keyword": "name"}, "Alice"], [{"$keyword": "age"}, 30]]}}
{"name": "map-union-overrides", "query": "{:age 20} | union({:age 30})", "expect": {"$map": [[{"$keyword": "age"}, 30]]}}
{"name": "map-minus-by-map", "query": "{:a 1 :b 2 :c 3} | minus({:b 99 :d 5})", "expect": {"$map": [[{"$keyword": "a"}, 1], [{"$keyword": "c"}, 3]]}}
{"name": "map-inter-by-map", "query": "{:a 1 :b 2 :c 3} | inter({:b 99 :d 5})", "expect": {"$map": [[{"$keyword": "b"}, 2]]}}
{"name": "map-minus-by-set", "query": "{:name \"Alice\" :age 30 :tmp 1} | minus(#{:tmp})", "expect": {"$map": [[{"$keyword": "name"}, "Alice"], [{"$keyword": "age"}, 30]]}}
{"name": "map-inter-by-set", "query": "{:name \"Alice\" :age 30 :tmp 1} | inter(#{:name :age})", "expect": {"$map": [[{"$keyword": "name"}, "Alice"], [{"$keyword": "age"}, 30]]}}
{"name": "enrich-with-derived", "query": "{:name \"Alice\" :age 20} | union({:adult /age | gte(18)})", "expect": {"$map": [[{"$keyword": "name"}, "Alice"], [{"$keyword": "age"}, 20], [{"$keyword": "adult"}, true]]}}
{"name": "bare-union-sets-two", "query": "[#{:a :b :c} #{:b :d}] | union", "expect": {"$set": [{"$keyword": "a"}, {"$keyword": "b"}, {"$keyword": "c"}, {"$keyword": "d"}]}}
{"name": "bare-union-sets-three", "query": "[#{:a} #{:b} #{:c}] | union", "expect": {"$set": [{"$keyword": "a"}, {"$keyword": "b"}, {"$keyword": "c"}]}}
{"name": "bare-minus-sets", "query": "[#{:a :b :c} #{:b :d}] | minus", "expect": {"$set": [{"$keyword": "a"}, {"$keyword": "c"}]}}
{"name": "bare-inter-sets", "query": "[#{:a :b :c} #{:b :d}] | inter", "expect": {"$set": [{"$keyword": "b"}]}}
{"name": "bare-union-maps", "query": "[{:name \"Alice\"} {:score 100}] | union", "expect": {"$map": [[{"$keyword": "name"}, "Alice"], [{"$keyword": "score"}, 100]]}}
{"name": "bare-union-empty-error", "query": "[] | union", "error": "type-error"}
{"name": "bare-union-singleton", "query": "[#{:only}] | union", "expect": {"$set": [{"$keyword": "only"}]}}
{"name": "full-union-maps", "query": "{:anchor true} | union({:name \"Alice\"}, {:age 30})", "expect": {"$map": [[{"$keyword": "name"}, "Alice"], [{"$keyword": "age"}, 30]]}}
