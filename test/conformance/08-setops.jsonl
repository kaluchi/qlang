{"name":"set-union","query":"#{:a :b :c} | union(#{:b :d})","expect":"#{:a :b :c :d}"}
{"name":"set-minus","query":"#{:a :b :c} | minus(#{:b :d})","expect":"#{:a :c}"}
{"name":"set-inter","query":"#{:a :b :c} | inter(#{:b :d})","expect":"#{:b}"}
{"name":"map-union-bound","query":"{:name \"Alice\"} | union({:age 30})","expect":"{:name \"Alice\" :age 30}"}
{"name":"map-union-overrides","query":"{:age 20} | union({:age 30})","expect":"{:age 30}"}
{"name":"map-minus-by-map","query":"{:a 1 :b 2 :c 3} | minus({:b 99 :d 5})","expect":"{:a 1 :c 3}"}
{"name":"map-inter-by-map","query":"{:a 1 :b 2 :c 3} | inter({:b 99 :d 5})","expect":"{:b 2}"}
{"name":"map-minus-by-set","query":"{:name \"Alice\" :age 30 :tmp 1} | minus(#{:tmp})","expect":"{:name \"Alice\" :age 30}"}
{"name":"map-inter-by-set","query":"{:name \"Alice\" :age 30 :tmp 1} | inter(#{:name :age})","expect":"{:name \"Alice\" :age 30}"}
{"name":"enrich-with-derived","query":"{:name \"Alice\" :age 20} | union({:adult /age | gte(18)})","expect":"{:name \"Alice\" :age 20 :adult true}"}
{"name":"bare-union-sets-two","query":"[#{:a :b :c} #{:b :d}] | union","expect":"#{:a :b :c :d}"}
{"name":"bare-union-sets-three","query":"[#{:a} #{:b} #{:c}] | union","expect":"#{:a :b :c}"}
{"name":"bare-minus-sets","query":"[#{:a :b :c} #{:b :d}] | minus","expect":"#{:a :c}"}
{"name":"bare-inter-sets","query":"[#{:a :b :c} #{:b :d}] | inter","expect":"#{:b}"}
{"name":"bare-union-maps","query":"[{:name \"Alice\"} {:score 100}] | union","expect":"{:name \"Alice\" :score 100}"}
{"name": "bare-union-empty-error", "query": "[] | union", "error": "type-error"}
{"name":"bare-union-singleton","query":"[#{:only}] | union","expect":"#{:only}"}
{"name":"full-union-maps","query":"{:anchor true} | union({:name \"Alice\"}, {:age 30})","expect":"{:name \"Alice\" :age 30}"}
