{"name":"tree-sum-leaf","query":"let(:totalSize, add(/size, /children * totalSize | sum)) | {:size 100 :children []} | totalSize","expect":"100"}
{"name":"tree-sum-flat","query":"let(:totalSize, add(/size, /children * totalSize | sum)) | {:size 0 :children [{:size 100 :children []} {:size 200 :children []}]} | totalSize","expect":"300"}
{"name":"tree-sum-nested-directories","query":"let(:totalSize, add(/size, /children * totalSize | sum)) | {:label \"root\" :size 0 :children [{:label \"README.md\" :size 2048 :children []} {:label \"src\" :size 0 :children [{:label \"main.c\" :size 512 :children []} {:label \"util.c\" :size 256 :children []}]}]} | totalSize","expect":"2816"}
{"name":"tree-count-nodes","query":"let(:countNodes, add(1, /children * countNodes | sum)) | {:children [{:children []} {:children [{:children []} {:children []}]}]} | countNodes","expect":"5"}
{"name":"tree-flatten-labels","query":"let(:allLabels, [[/label], /children * allLabels | flat] | flat) | {:label \"root\" :children [{:label \"a\" :children []} {:label \"b\" :children [{:label \"c\" :children []}]}]} | allLabels","expect":"[\"root\" \"a\" \"b\" \"c\"]"}
{"name":"tree-enrich-with-count","query":"let(:withCounts, {:label /label :count /children | count :children /children * withCounts}) | {:label \"root\" :children [{:label \"a\" :children []} {:label \"b\" :children [{:label \"c\" :children []}]}]} | withCounts","expect":"{:label \"root\" :count 2 :children [{:label \"a\" :count 0 :children []} {:label \"b\" :count 1 :children [{:label \"c\" :count 0 :children []}]}]}"}
{"name":"tree-empty-children-terminates","query":"let(:walk, {:label /label :children /children * walk}) | {:label \"only\" :children []} | walk","expect":"{:label \"only\" :children []}"}
