{"name": "reify-builtin-via-projection-kind", "query": "env | /count | reify | /kind", "expect": {"$keyword": "builtin"}}
{"name": "reify-builtin-via-projection-name", "query": "env | /count | reify | /name", "expect": "count"}
{"name": "reify-builtin-arity", "query": "env | /count | reify | /arity", "expect": 1}
{"name": "reify-builtin-category", "query": "env | /filter | reify | /category", "expect": {"$keyword": "vec-transformer"}}
{"name": "reify-builtin-docs-is-vec", "query": "env | /count | reify | /docs | count", "expect": 1}
{"name": "reify-builtin-docs-first", "query": "env | /count | reify | /docs | first", "expect": "Returns the number of elements. Polymorphic over Vec (length), Set (size), and Map (entry count)."}
{"name": "reify-builtin-modifiers", "query": "env | /add | reify | /modifiers", "expect": ["number"]}
{"name": "reify-builtin-returns", "query": "env | /add | reify | /returns", "expect": "number"}
{"name": "reify-builtin-throws-contains-class", "query": "env | /add | reify | /throws | first", "expect": "AddLeftNotNumber"}
{"name": "reify-by-name-builtin", "query": "reify(:count) | /kind", "expect": {"$keyword": "builtin"}}
{"name": "reify-by-name-attaches-name", "query": "reify(:filter) | /name", "expect": "filter"}
{"name": "reify-by-name-unresolved", "query": "reify(:nonexistentBinding)", "error": "unresolved-identifier"}
{"name": "reify-thunk-kind", "query": "let double = mul(2) | reify(:double) | /kind", "expect": {"$keyword": "thunk"}}
{"name": "reify-thunk-name", "query": "let double = mul(2) | reify(:double) | /name", "expect": "double"}
{"name": "reify-thunk-source-renders-body", "query": "let double = mul(2) | reify(:double) | /source", "expect": "mul(2)"}
{"name": "reify-thunk-empty-docs-when-undeclared", "query": "let double = mul(2) | reify(:double) | /docs", "expect": []}
{"name": "reify-thunk-with-line-doc", "query": "|~~| Удваивает.\n| let double = mul(2)\n| reify(:double) | /docs", "expect": [" Удваивает."]}
{"name": "reify-snapshot-kind", "query": "42 | as answer | reify(:answer) | /kind", "expect": {"$keyword": "snapshot"}}
{"name": "reify-snapshot-value", "query": "42 | as answer | reify(:answer) | /value", "expect": 42}
{"name": "reify-snapshot-type-number", "query": "42 | as answer | reify(:answer) | /type", "expect": {"$keyword": "number"}}
{"name": "reify-snapshot-type-string", "query": "\"hello\" | as greeting | reify(:greeting) | /type", "expect": {"$keyword": "string"}}
{"name": "reify-snapshot-type-vec", "query": "[1 2 3] | as nums | reify(:nums) | /type", "expect": {"$keyword": "vec"}}
{"name": "reify-snapshot-with-doc", "query": "42\n|~~| Captured snapshot.\n| as answer\n| reify(:answer) | /docs | first", "expect": " Captured snapshot."}
{"name": "reify-value-kind-on-bare-number", "query": "42 | reify | /kind", "expect": {"$keyword": "value"}}
{"name": "reify-value-of-number", "query": "42 | reify | /value", "expect": 42}
{"name": "reify-value-type-string", "query": "\"hi\" | reify | /type", "expect": {"$keyword": "string"}}
{"name": "reify-value-of-vec", "query": "[1 2 3] | reify | /kind", "expect": {"$keyword": "value"}}
{"name": "reify-key-not-keyword-error", "query": "reify(\"count\")", "error": "type-error"}
{"name": "manifest-returns-vec", "query": "env | manifest | count | gt(30)", "expect": true}
{"name": "manifest-contains-count", "query": "env | manifest | filter(/name | eq(\"count\")) | count", "expect": 1}
{"name": "manifest-filter-by-builtin-kind", "query": "env | manifest | filter(/kind | eq(:builtin)) | count | gt(20)", "expect": true}
{"name": "manifest-filter-by-thunk-kind", "query": "let foo = 42 | env | manifest | filter(/kind | eq(:thunk)) | count", "expect": 1}
{"name": "manifest-includes-arith-category", "query": "env | manifest | filter(/category | eq(:arith)) | count", "expect": 4}
{"name": "reify-value-type-nil", "query": "nil | reify | /type", "expect": {"$keyword": "nil"}}
{"name": "reify-value-type-boolean", "query": "true | reify | /type", "expect": {"$keyword": "boolean"}}
{"name": "reify-value-type-keyword", "query": ":foo | reify | /type", "expect": {"$keyword": "keyword"}}
{"name": "reify-value-type-map", "query": "{:a 1} | reify | /type", "expect": {"$keyword": "map"}}
{"name": "reify-value-type-set", "query": "#{1 2 3} | reify | /type", "expect": {"$keyword": "set"}}
{"name": "reify-snapshot-vec-type", "query": "[1 2 3] | as nums | reify(:nums) | /type", "expect": {"$keyword": "vec"}}
{"name": "reify-snapshot-map-type", "query": "{:a 1} | as obj | reify(:obj) | /type", "expect": {"$keyword": "map"}}
{"name": "reify-snapshot-keyword-type", "query": ":foo | as kw | reify(:kw) | /type", "expect": {"$keyword": "keyword"}}
{"name": "reify-snapshot-boolean-type", "query": "true | as flag | reify(:flag) | /type", "expect": {"$keyword": "boolean"}}
{"name": "reify-snapshot-nil-type", "query": "nil | as none | reify(:none) | /type", "expect": {"$keyword": "nil"}}
{"name": "reify-by-name-on-bare-value-via-use", "query": "{:pi 3.14} | use | reify(:pi) | /value", "expect": 3.14}
{"name": "reify-by-name-on-bare-value-name", "query": "{:pi 3.14} | use | reify(:pi) | /name", "expect": "pi"}
{"name": "reify-by-name-on-bare-value-kind", "query": "{:pi 3.14} | use | reify(:pi) | /kind", "expect": {"$keyword": "value"}}

