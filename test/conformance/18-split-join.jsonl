{"name": "split-comma", "query": "\"a,b,c\" | split(\",\")", "expect": ["a", "b", "c"]}
{"name": "split-newline", "query": "\"line1\\nline2\\nline3\" | split(\"\\n\")", "expect": ["line1", "line2", "line3"]}
{"name": "split-empty-string", "query": "\"\" | split(\",\")", "expect": [""]}
{"name": "split-no-occurrences", "query": "\"abc\" | split(\",\")", "expect": ["abc"]}
{"name": "split-single-char-separator", "query": "\"x-y-z\" | split(\"-\")", "expect": ["x", "y", "z"]}
{"name": "split-multi-char-separator", "query": "\"a::b::c\" | split(\"::\")", "expect": ["a", "b", "c"]}
{"name": "join-comma", "query": "[\"a\" \"b\" \"c\"] | join(\",\")", "expect": "a,b,c"}
{"name": "join-empty-vec", "query": "[] | join(\",\")", "expect": ""}
{"name": "join-singleton", "query": "[\"only\"] | join(\",\")", "expect": "only"}
{"name": "join-empty-separator", "query": "[\"x\" \"y\" \"z\"] | join(\"\")", "expect": "xyz"}
{"name": "join-multi-char-separator", "query": "[\"a\" \"b\"] | join(\" :: \")", "expect": "a :: b"}
{"name": "split-then-join-roundtrip", "query": "\"a,b,c\" | split(\",\") | join(\",\")", "expect": "a,b,c"}
{"name": "join-then-split-roundtrip", "query": "[\"a\" \"b\" \"c\"] | join(\",\") | split(\",\")", "expect": ["a", "b", "c"]}
{"name": "split-subject-not-string", "query": "42 | split(\",\")", "error": "type-error"}
{"name": "split-separator-not-string", "query": "\"abc\" | split(42)", "error": "type-error"}
{"name": "join-subject-not-vec", "query": "42 | join(\",\")", "error": "type-error"}
{"name": "join-element-not-string", "query": "[\"a\" 42 \"c\"] | join(\",\")", "error": "type-error"}
{"name": "join-separator-not-string", "query": "[\"a\" \"b\"] | join(42)", "error": "type-error"}
