{"name":"runtime-error-thrown","query":"\"hello\" | add(1) !| /thrown","expect":":AddLeftNotNumber"}
{"name":"runtime-error-origin","query":"\"hello\" | add(1) !| /origin","expect":":qlang/eval"}
