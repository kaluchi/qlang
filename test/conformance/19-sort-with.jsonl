{"name": "sortWith-inline-asc-numbers", "query": "[3 1 2] | sortWith(sub(/left, /right))", "expect": [1, 2, 3]}
{"name": "sortWith-inline-desc-numbers", "query": "[3 1 2] | sortWith(sub(/right, /left))", "expect": [3, 2, 1]}
{"name": "sortWith-asc-projection", "query": "[{:age 30} {:age 20} {:age 25}] | sortWith(asc(/age)) * /age", "expect": [20, 25, 30]}
{"name": "sortWith-desc-projection", "query": "[{:age 30} {:age 20} {:age 25}] | sortWith(desc(/age)) * /age", "expect": [30, 25, 20]}
{"name": "sortWith-asc-on-strings", "query": "[{:name \"Charlie\"} {:name \"Alice\"} {:name \"Bob\"}] | sortWith(asc(/name)) * /name", "expect": ["Alice", "Bob", "Charlie"]}
{"name": "sortWith-desc-on-strings", "query": "[{:name \"Charlie\"} {:name \"Alice\"} {:name \"Bob\"}] | sortWith(desc(/name)) * /name", "expect": ["Charlie", "Bob", "Alice"]}
{"name": "sortWith-asc-on-computed-key", "query": "[{:p 10 :q 3} {:p 5 :q 10}] | sortWith(asc(mul(/p, /q))) * mul(/p, /q)", "expect": [30, 50]}
{"name": "sortWith-asc-nested-projection", "query": "[{:profile {:joined 2024}} {:profile {:joined 2020}} {:profile {:joined 2022}}] | sortWith(asc(/profile/joined)) * /profile/joined", "expect": [2020, 2022, 2024]}
{"name": "sortWith-empty-vec", "query": "[] | sortWith(asc(/x))", "expect": []}
{"name": "sortWith-singleton-vec", "query": "[42] | sortWith(asc(/left))", "expect": [42]}
{"name": "sortWith-stable-on-equal", "query": "[{:k 1 :tag \"a\"} {:k 1 :tag \"b\"} {:k 1 :tag \"c\"}] | sortWith(asc(/k)) * /tag", "expect": ["a", "b", "c"]}
{"name": "sortWith-subject-not-vec", "query": "42 | sortWith(asc(/x))", "error": "type-error"}
{"name": "sortWith-cmp-result-not-number", "query": "[1 2] | sortWith(\"not a number\")", "error": "type-error"}
{"name": "asc-keys-not-comparable", "query": "[{:k 1} {:k \"a\"}] | sortWith(asc(/k))", "error": "type-error"}
{"name": "desc-keys-not-comparable", "query": "[{:k 1} {:k \"a\"}] | sortWith(desc(/k))", "error": "type-error"}
{"name": "firstNonZero-pick-first", "query": "[0 0 -1 5] | firstNonZero", "expect": -1}
{"name": "firstNonZero-positive", "query": "[0 7 -3] | firstNonZero", "expect": 7}
{"name": "firstNonZero-all-zero", "query": "[0 0 0] | firstNonZero", "expect": 0}
{"name": "firstNonZero-empty", "query": "[] | firstNonZero", "expect": 0}
{"name": "firstNonZero-singleton-non-zero", "query": "[5] | firstNonZero", "expect": 5}
{"name": "firstNonZero-singleton-zero", "query": "[0] | firstNonZero", "expect": 0}
{"name": "firstNonZero-subject-not-vec", "query": "42 | firstNonZero", "error": "type-error"}
{"name": "firstNonZero-element-not-number", "query": "[0 \"two\" 1] | firstNonZero", "error": "type-error"}
{"name": "compound-name-asc-then-age-desc", "query": "[{:n \"B\" :a 30} {:n \"A\" :a 20} {:n \"B\" :a 25}] | sortWith([asc(/n), desc(/a)] | firstNonZero) * /a", "expect": [20, 30, 25]}
{"name": "compound-three-keys", "query": "[{:dept \"eng\" :seniority 5 :name \"Bob\"} {:dept \"eng\" :seniority 5 :name \"Alice\"} {:dept \"eng\" :seniority 8 :name \"Carol\"} {:dept \"sales\" :seniority 3 :name \"Dan\"}] | sortWith([asc(/dept), desc(/seniority), asc(/name)] | firstNonZero) * /name", "expect": ["Carol", "Alice", "Bob", "Dan"]}
{"name": "compound-all-tied-stable-original-order", "query": "[{:k 1 :tag \"a\"} {:k 1 :tag \"b\"} {:k 1 :tag \"c\"}] | sortWith([asc(/k)] | firstNonZero) * /tag", "expect": ["a", "b", "c"]}
{"name": "asc-pair-not-map", "query": "[1 2] | sortWith(asc(/x))", "error": "type-error"}
