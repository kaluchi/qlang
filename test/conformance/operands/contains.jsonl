{"name": "needle-found-mid", "query": "\"hello world\" | contains(\"lo wor\")", "expect": true}
{"name": "needle-found-at-start", "query": "\"hello world\" | contains(\"hello\")", "expect": true}
{"name": "needle-found-at-end", "query": "\"hello world\" | contains(\"world\")", "expect": true}
{"name": "needle-not-found", "query": "\"hello\" | contains(\"xyz\")", "expect": false}
{"name": "empty-needle-always-contained", "query": "\"anything\" | contains(\"\")", "expect": true}
{"name": "empty-subject-only-contains-empty", "query": "\"\" | contains(\"\")", "expect": true}
{"name": "empty-subject-not-contains-non-empty", "query": "\"\" | contains(\"x\")", "expect": false}
{"name": "case-sensitive", "query": "\"Hello\" | contains(\"hello\")", "expect": false}
{"name": "needle-equals-subject", "query": "\"foo\" | contains(\"foo\")", "expect": true}
{"name": "subject-not-string-throws", "query": "42 | contains(\"x\")", "error": "type-error"}
{"name": "needle-not-string-throws", "query": "\"hi\" | contains(42)", "error": "type-error"}
{"name": "filter-vec-by-substring", "query": "[\"alice\" \"bob\" \"alex\"] | filter(contains(\"al\"))", "expect": ["alice", "alex"]}
{"name": "filter-by-projection-and-contains", "query": "[{:name \"alice\"} {:name \"bob\"} {:name \"alex\"}] | filter(/name | contains(\"al\")) * /name", "expect": ["alice", "alex"]}
