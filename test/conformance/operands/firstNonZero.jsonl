{"name": "all-zero-returns-zero", "query": "[0 0 0] | firstNonZero", "expect": 0}
{"name": "single-zero", "query": "[0] | firstNonZero", "expect": 0}
{"name": "single-positive", "query": "[5] | firstNonZero", "expect": 5}
{"name": "single-negative", "query": "[-3] | firstNonZero", "expect": -3}
{"name": "empty-vec-returns-zero", "query": "[] | firstNonZero", "expect": 0}
{"name": "first-element-non-zero-positive", "query": "[7 0 3] | firstNonZero", "expect": 7}
{"name": "first-element-non-zero-negative", "query": "[-2 0 3] | firstNonZero", "expect": -2}
{"name": "second-element-after-zero", "query": "[0 5 0] | firstNonZero", "expect": 5}
{"name": "third-element-after-two-zeros", "query": "[0 0 -1 5] | firstNonZero", "expect": -1}
{"name": "last-element-after-many-zeros", "query": "[0 0 0 0 42] | firstNonZero", "expect": 42}
{"name": "all-positive-takes-first", "query": "[1 2 3] | firstNonZero", "expect": 1}
{"name": "all-negative-takes-first", "query": "[-1 -2 -3] | firstNonZero", "expect": -1}
{"name": "mix-positive-negative-takes-first", "query": "[3 -5 7] | firstNonZero", "expect": 3}
{"name": "decimal-non-zero", "query": "[0 3.14 0] | firstNonZero", "expect": 3.14}
{"name": "very-small-non-zero", "query": "[0 0.0001 0] | firstNonZero", "expect": 0.0001}
{"name": "negative-decimal", "query": "[0 -2.5] | firstNonZero", "expect": -2.5}
{"name": "subject-not-vec-error", "query": "42 | firstNonZero", "error": "type-error"}
{"name": "subject-string-error", "query": "\"abc\" | firstNonZero", "error": "type-error"}
{"name": "subject-map-error", "query": "{:a 1} | firstNonZero", "error": "type-error"}
{"name": "subject-set-error", "query": "#{1 2 3} | firstNonZero", "error": "type-error"}
{"name": "subject-nil-error", "query": "nil | firstNonZero", "error": "type-error"}
{"name": "element-string-error", "query": "[0 \"two\" 1] | firstNonZero", "error": "type-error"}
{"name": "element-nil-error", "query": "[0 nil 1] | firstNonZero", "error": "type-error"}
{"name": "element-vec-error", "query": "[0 [1] 1] | firstNonZero", "error": "type-error"}
{"name": "element-keyword-error", "query": "[0 :foo 1] | firstNonZero", "error": "type-error"}
{"name": "element-bool-error", "query": "[0 true 1] | firstNonZero", "error": "type-error"}
{"name": "compose-with-vec-of-comparators", "query": "[{:a 1 :b 2} {:a 1 :b 5} {:a 2 :b 1}] | sortWith([asc(/a), desc(/b)] | firstNonZero) * /b", "expect": [5, 2, 1]}
{"name": "compose-bare-numeric-vec-from-arithmetic", "query": "[{:n 1} {:n 2} {:n 3}] * /n | as(:nums) | nums * sub(2) | firstNonZero", "expect": -1}
