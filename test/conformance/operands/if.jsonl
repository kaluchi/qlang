{"name":"cond-truthy-runs-then","query":"75 | if(gte(60), \"pass\", \"fail\")","expect":"\"pass\""}
{"name":"cond-falsy-runs-else","query":"5 | if(gte(60), \"pass\", \"fail\")","expect":"\"fail\""}
{"name":"cond-true-literal","query":"42 | if(true, \"yes\", \"no\")","expect":"\"yes\""}
{"name":"cond-false-literal","query":"42 | if(false, \"yes\", \"no\")","expect":"\"no\""}
{"name":"cond-nil-is-falsy","query":"{:no \"data\"} | if(/missing, \"yes\", \"no\")","expect":"\"no\""}
{"name":"cond-zero-is-truthy","query":"5 | if(eq(0), \"is-zero\", \"non-zero\")","expect":"\"non-zero\""}
{"name":"cond-empty-string-is-truthy","query":"\"\" | if(eq(\"\"), \"empty\", \"non\")","expect":"\"empty\""}
{"name":"cond-empty-vec-is-truthy","query":"[] | if(empty | not, \"non-empty\", \"empty\")","expect":"\"empty\""}
{"name":"cond-empty-map-is-truthy-via-not-eq","query":"{} | if(eq({}), \"empty-map\", \"other\")","expect":"\"empty-map\""}
{"name":"cond-using-and","query":"{:active true :verified true} | if(and(/active, /verified), \"go\", \"stop\")","expect":"\"go\""}
{"name":"cond-using-or","query":"{:vip false :score 99} | if(or(/vip, /score | gt(95)), \"premium\", \"standard\")","expect":"\"premium\""}
{"name":"cond-using-not","query":"true | if(not, \"truthy\", \"falsy\")","expect":"\"falsy\""}
{"name":"then-uses-pipevalue-via-projection","query":"{:active true :salary 100} | if(/active, /salary | mul(11) | div(10), /salary)","expect":"110"}
{"name":"else-uses-pipevalue-via-projection","query":"{:active false :salary 100} | if(/active, /salary | mul(11) | div(10), /salary)","expect":"100"}
{"name":"then-arithmetic","query":"10 | if(gt(5), mul(2), mul(0))","expect":"20"}
{"name":"else-arithmetic","query":"3 | if(gt(5), mul(2), mul(0))","expect":"0"}
{"name":"then-literal-string","query":"1 | if(true, \"hello\", \"goodbye\")","expect":"\"hello\""}
{"name":"else-literal-string","query":"1 | if(false, \"hello\", \"goodbye\")","expect":"\"goodbye\""}
{"name":"lazy-else-not-evaluated-when-cond-truthy","query":"10 | if(gt(0), \"positive\", div(0))","expect":"\"positive\""}
{"name":"lazy-then-not-evaluated-when-cond-falsy","query":"10 | if(lt(0), div(0), \"non-negative\")","expect":"\"non-negative\""}
{"name":"nested-if-three-way","query":"75 | if(gte(90), \"A\", if(gte(70), \"B\", \"C\"))","expect":"\"B\""}
{"name":"nested-if-A-grade","query":"95 | if(gte(90), \"A\", if(gte(70), \"B\", \"C\"))","expect":"\"A\""}
{"name":"nested-if-C-grade","query":"55 | if(gte(90), \"A\", if(gte(70), \"B\", \"C\"))","expect":"\"C\""}
{"name":"if-inside-distribute-numbers","query":"[1 2 3 4 5] * if(gt(2), \"big\", \"small\")","expect":"[\"small\" \"small\" \"big\" \"big\" \"big\"]"}
{"name":"if-inside-distribute-doubles-some","query":"[1 2 3 4 5] * if(gt(2), mul(10), add(0))","expect":"[1 2 30 40 50]"}
{"name":"if-inside-filter-via-truthy-result","query":"[1 2 3 4] | filter(if(gt(2), true, false))","expect":"[3 4]"}
{"name":"if-inside-reshape","query":"[{:n 5} {:n 15}] * {:value /n :tier if(/n | gt(10), \"high\", \"low\")}","expect":"[{:value 5 :tier \"low\"} {:value 15 :tier \"high\"}]"}
{"name":"if-with-coalesce","query":"{:role :admin :name \"Bob\"} | if(/role | eq(:admin), coalesce(/displayName, /name, \"???\"), \"guest\")","expect":"\"Bob\""}
{"name":"if-cond-on-eq-keyword","query":"{:status :ok} | if(/status | eq(:ok), 200, 500)","expect":"200"}
{"name":"if-cond-on-eq-keyword-failing","query":"{:status :error} | if(/status | eq(:ok), 200, 500)","expect":"500"}
{"name":"if-with-deeply-nested-cond","query":"{:a {:b {:c true}}} | if(/a/b/c, \"deep-yes\", \"deep-no\")","expect":"\"deep-yes\""}
