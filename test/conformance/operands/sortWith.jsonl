{"name": "inline-asc-numbers", "query": "[3 1 2] | sortWith(sub(/left, /right))", "expect": [1, 2, 3]}
{"name": "inline-desc-numbers", "query": "[3 1 2] | sortWith(sub(/right, /left))", "expect": [3, 2, 1]}
{"name": "inline-asc-with-many-elements", "query": "[5 3 1 4 2] | sortWith(sub(/left, /right))", "expect": [1, 2, 3, 4, 5]}
{"name": "empty-vec", "query": "[] | sortWith(asc(/x))", "expect": []}
{"name": "singleton-vec", "query": "[42] | sortWith(asc(/left))", "expect": [42]}
{"name": "two-elements-already-sorted", "query": "[1 2] | sortWith(sub(/left, /right))", "expect": [1, 2]}
{"name": "two-elements-reversed", "query": "[2 1] | sortWith(sub(/left, /right))", "expect": [1, 2]}
{"name": "stable-on-equal", "query": "[{:k 1 :tag \"a\"} {:k 1 :tag \"b\"} {:k 1 :tag \"c\"}] | sortWith(asc(/k)) * /tag", "expect": ["a", "b", "c"]}
{"name": "stable-on-partial-tie", "query": "[{:k 2 :tag \"x\"} {:k 1 :tag \"y\"} {:k 1 :tag \"z\"}] | sortWith(asc(/k)) * /tag", "expect": ["y", "z", "x"]}
{"name": "with-asc-helper-on-projection", "query": "[{:age 30} {:age 20} {:age 25}] | sortWith(asc(/age)) * /age", "expect": [20, 25, 30]}
{"name": "with-desc-helper-on-projection", "query": "[{:age 30} {:age 20} {:age 25}] | sortWith(desc(/age)) * /age", "expect": [30, 25, 20]}
{"name": "with-asc-on-strings", "query": "[{:n \"Charlie\"} {:n \"Alice\"} {:n \"Bob\"}] | sortWith(asc(/n)) * /n", "expect": ["Alice", "Bob", "Charlie"]}
{"name": "with-asc-on-computed-key", "query": "[{:p 10 :q 3} {:p 5 :q 10}] | sortWith(asc(mul(/p, /q))) * mul(/p, /q)", "expect": [30, 50]}
{"name": "with-asc-on-nested-projection", "query": "[{:profile {:joined 2024}} {:profile {:joined 2020}}] | sortWith(asc(/profile/joined)) * /profile/joined", "expect": [2020, 2024]}
{"name": "with-asc-on-children-count", "query": "[{:c [1 2 3]} {:c []} {:c [1]}] | sortWith(asc(/c | count)) * (/c | count)", "expect": [0, 1, 3]}
{"name": "with-desc-on-children-count", "query": "[{:c [1 2 3]} {:c []} {:c [1]}] | sortWith(desc(/c | count)) * (/c | count)", "expect": [3, 1, 0]}
{"name": "compound-name-asc-then-age-desc", "query": "[{:n \"B\" :a 30} {:n \"A\" :a 20} {:n \"B\" :a 25}] | sortWith([asc(/n), desc(/a)] | firstNonZero) * /a", "expect": [20, 30, 25]}
{"name": "compound-three-keys", "query": "[{:dept \"eng\" :seniority 5 :name \"Bob\"} {:dept \"eng\" :seniority 5 :name \"Alice\"} {:dept \"eng\" :seniority 8 :name \"Carol\"} {:dept \"sales\" :seniority 3 :name \"Dan\"}] | sortWith([asc(/dept), desc(/seniority), asc(/name)] | firstNonZero) * /name", "expect": ["Carol", "Alice", "Bob", "Dan"]}
{"name": "compound-with-recursive-let-key", "query": "let(:total, add(1, /children * total | sum)) | [{:children [{:children [{:children []}]} {:children []}]} {:children [{:children []} {:children []}]}] | sortWith([desc(/children | count), desc(total)] | firstNonZero) * total", "expect": [4, 3]}
{"name": "after-filter", "query": "[{:n 1} {:n 5} {:n 2} {:n 8}] | filter(/n | gt(2)) | sortWith(asc(/n)) * /n", "expect": [5, 8]}
{"name": "after-distinct", "query": "[3 1 2 1 3] | distinct | sortWith(sub(/left, /right))", "expect": [1, 2, 3]}
{"name": "subject-not-vec-error", "query": "42 | sortWith(asc(/x))", "error": "type-error"}
{"name": "subject-map-error", "query": "{:a 1} | sortWith(asc(/x))", "error": "type-error"}
{"name": "subject-set-error", "query": "#{1 2 3} | sortWith(asc(/x))", "error": "type-error"}
{"name": "cmp-result-not-number-error", "query": "[1 2] | sortWith(\"not a number\")", "error": "type-error"}
{"name": "cmp-result-keyword-error", "query": "[1 2] | sortWith(:tag)", "error": "type-error"}
{"name": "jdt-style-members-by-name", "query": "[{:kind :method :name \"handle\" :public true} {:kind :method :name \"bind\" :public true} {:kind :field :name \"port\" :public false}] | filter(/kind | eq(:method)) | filter(/public) | sortWith(asc(/name)) * /name", "expect": ["bind", "handle"]}
{"name": "jdt-style-by-callers-count-desc", "query": "[{:fqmn \"A#f\" :callers [1 2 3]} {:fqmn \"A#g\" :callers [1]} {:fqmn \"A#h\" :callers [1 2 3 4 5]}] | sortWith(desc(/callers | count)) * /fqmn", "expect": ["A#h", "A#f", "A#g"]}
{"name": "jdt-style-compound-severity-then-name", "query": "[{:name \"active\" :severity 2} {:name \"old\" :severity 5} {:name \"alpha\" :severity 2}] | sortWith([asc(/severity), asc(/name)] | firstNonZero) * /name", "expect": ["active", "alpha", "old"]}
{"name": "jdt-style-top-callers", "query": "[{:fqmn \"A\" :callers [1 2 3]} {:fqmn \"B\" :callers [1 2 3 4 5]} {:fqmn \"C\" :callers [1 2]} {:fqmn \"D\" :callers [1 2 3 4]}] | sortWith(desc(/callers | count)) | take(2) * /fqmn", "expect": ["B", "D"]}

