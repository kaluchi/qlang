{"name":"prefix-matches","query":"\"hello world\" | startsWith(\"hello\")","expect":"true"}
{"name":"prefix-equals-subject","query":"\"hello\" | startsWith(\"hello\")","expect":"true"}
{"name":"prefix-not-matching","query":"\"hello\" | startsWith(\"world\")","expect":"false"}
{"name":"prefix-longer-than-subject","query":"\"hi\" | startsWith(\"hello\")","expect":"false"}
{"name":"empty-prefix-always-true","query":"\"anything\" | startsWith(\"\")","expect":"true"}
{"name":"empty-subject-empty-prefix","query":"\"\" | startsWith(\"\")","expect":"true"}
{"name":"case-sensitive","query":"\"Hello\" | startsWith(\"hello\")","expect":"false"}
{"name": "subject-not-string-throws", "query": "42 | startsWith(\"x\")", "error": "type-error"}
{"name": "prefix-not-string-throws", "query": "\"hi\" | startsWith(42)", "error": "type-error"}
{"name":"filter-vec-by-prefix","query":"[\"alice\" \"bob\" \"alex\"] | filter(startsWith(\"al\"))","expect":"[\"alice\" \"alex\"]"}
{"name":"filter-by-projection-prefix","query":"[{:path \"/usr/bin\"} {:path \"/etc/hosts\"} {:path \"/usr/lib\"}] | filter(/path | startsWith(\"/usr\")) * /path","expect":"[\"/usr/bin\" \"/usr/lib\"]"}
