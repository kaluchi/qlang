{
  "name": "qlang-syntax",
  "displayName": "qlang",
  "description": "Syntax highlighting for the qlang query language",
  "version": "0.1.0",
  "publisher": "local",
  "engines": { "vscode": "^1.60.0" },
  "contributes": {
    "languages": [
      {
        "id": "qlang",
        "aliases": ["qlang"],
        "extensions": [".qlang"],
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "qlang",
        "path": "./snippets/qlang.json"
      }
    ],
    "grammars": [
      {
        "language": "qlang",
        "scopeName": "source.qlang",
        "path": "./syntaxes/qlang.tmLanguage.json"
      },
      {
        "scopeName": "markdown.qlang.codeblock",
        "path": "./syntaxes/qlang-markdown.tmLanguage.json",
        "injectTo": ["text.html.markdown"],
        "embeddedLanguages": {
          "meta.embedded.block.qlang": "qlang"
        }
      }
    ]
  }
}
