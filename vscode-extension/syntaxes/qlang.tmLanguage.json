{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "qlang",
  "scopeName": "source.qlang",
  "fileTypes": ["qlang"],
  "patterns": [
    { "include": "#comment-line-doc" },
    { "include": "#comment-block-doc" },
    { "include": "#comment-line-plain" },
    { "include": "#comment-block-plain" },
    { "include": "#string" },
    { "include": "#type-keyword" },
    { "include": "#map-key" },
    { "include": "#keyword-atom" },
    { "include": "#number" },
    { "include": "#constant" },
    { "include": "#projection" },
    { "include": "#set-open" },
    { "include": "#combinator" },
    { "include": "#effect-identifier" },
    { "include": "#keyword-binding" },
    { "include": "#builtin-operand" },
    { "include": "#identifier" },
    { "include": "#punctuation" }
  ],
  "repository": {

    "comment-line-doc": {
      "comment": "|~~| doc comment to end of line",
      "name": "comment.line.documentation.qlang",
      "match": "\\|~~\\|[^\\n]*"
    },
    "comment-block-doc": {
      "comment": "|~~ ... ~~| block doc",
      "name": "comment.block.documentation.qlang",
      "begin": "\\|~~(?!\\|)",
      "end": "~~\\|",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.qlang" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.qlang" } }
    },
    "comment-line-plain": {
      "comment": "|~| plain comment to end of line",
      "name": "comment.line.qlang",
      "match": "\\|~\\|[^\\n]*"
    },
    "comment-block-plain": {
      "comment": "|~ ... ~| block plain",
      "name": "comment.block.qlang",
      "begin": "\\|~(?![|~])",
      "end": "~\\|",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.qlang" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.qlang" } }
    },

    "string": {
      "name": "string.quoted.double.qlang",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.qlang" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.qlang" } },
      "patterns": [
        { "name": "constant.character.escape.qlang", "match": "\\\\[\"\\\\ntr]" },
        { "name": "invalid.illegal.escape.qlang",    "match": "\\\\." }
      ]
    },

    "type-keyword": {
      "comment": "qlang type-vocabulary keywords — the scalar, container, and lambda-parameter types from the spec. Tried before map-key and keyword-atom so type references get support.type scope.",
      "name": "support.type.qlang",
      "match": ":(number|string|boolean|keyword|nil|any|vec|map|set|predicate-lambda|key-lambda|comparator-lambda|pipeline)(?![a-zA-Z0-9_-])"
    },

    "map-key": {
      "comment": "Map key: bare keyword followed by required horizontal whitespace (MapEntry = key:Keyword __ value).",
      "match": "(:[a-zA-Z@_][a-zA-Z0-9_-]*)(?=[ \\t])",
      "captures": {
        "1": { "name": "support.type.property-name.qlang" }
      }
    },

    "keyword-atom": {
      "comment": "qlang keyword/symbol literals used as values",
      "patterns": [
        {
          "comment": "quoted keyword :\"...\"",
          "name": "constant.other.symbol.qlang",
          "begin": ":\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.constant.qlang" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.constant.qlang" } },
          "patterns": [
            { "name": "constant.character.escape.qlang", "match": "\\\\[\"\\\\ntr]" }
          ]
        },
        {
          "comment": "bare keyword :name",
          "name": "constant.other.symbol.qlang",
          "match": ":[@_a-zA-Z][a-zA-Z0-9_-]*"
        }
      ]
    },

    "number": {
      "name": "constant.numeric.qlang",
      "match": "(?<![a-zA-Z0-9_-])-?[0-9]+(?:\\.[0-9]+)?"
    },

    "constant": {
      "patterns": [
        {
          "name": "constant.language.boolean.qlang",
          "match": "\\b(true|false)(?![a-zA-Z0-9_-])"
        },
        {
          "name": "constant.language.nil.qlang",
          "match": "\\bnil(?![a-zA-Z0-9_-])"
        }
      ]
    },

    "projection": {
      "comment": "Path projection: /field or /\"quoted key\". Each /segment matched individually.",
      "patterns": [
        {
          "match": "(/)(\"(?:[^\\\\\"]|\\\\.)*\")",
          "captures": {
            "1": { "name": "keyword.operator.projection.qlang" },
            "2": { "name": "variable.other.member.qlang" }
          }
        },
        {
          "match": "(/)([@_a-zA-Z][a-zA-Z0-9_-]*)",
          "captures": {
            "1": { "name": "keyword.operator.projection.qlang" },
            "2": { "name": "variable.other.member.qlang" }
          }
        }
      ]
    },

    "set-open": {
      "comment": "Set literal opener #{",
      "name": "punctuation.definition.set.qlang",
      "match": "#\\{"
    },

    "combinator": {
      "comment": "Pipeline combinators: >> (chain), | (pipe), * (spread)",
      "patterns": [
        { "name": "keyword.operator.chain.qlang",  "match": ">>" },
        { "name": "keyword.operator.pipe.qlang",   "match": "\\|(?!~)" },
        { "name": "keyword.operator.spread.qlang", "match": "\\*" }
      ]
    },

    "effect-identifier": {
      "comment": "@-prefixed identifiers — effectful host operands per spec §'Effect markers'. @ sigil gets punctuation scope so themes can color it separately from the name.",
      "match": "(@)([a-zA-Z_][a-zA-Z0-9_-]*)",
      "captures": {
        "1": { "name": "punctuation.definition.variable.qlang" },
        "2": { "name": "variable.language.qlang" }
      }
    },

    "keyword-binding": {
      "comment": "let and as — the two binding forms of qlang. Semantically control-flow-adjacent: let declares a conduit, as captures a snapshot. Distinguished from other builtins.",
      "match": "(?<![a-zA-Z0-9_@-])(let|as)(?![a-zA-Z0-9_-])",
      "captures": {
        "1": { "name": "keyword.control.binding.qlang" }
      }
    },

    "builtin-operand": {
      "comment": "62 built-in operands from manifest.qlang (let and as handled separately by keyword-binding).",
      "match": "(?<![a-zA-Z0-9_@-])(count|empty|first|last|sum|min|max|every|any|firstNonZero|filter|sort|sortWith|take|drop|distinct|reverse|flat|set|groupBy|indexBy|asc|desc|nullsFirst|nullsLast|if|when|unless|coalesce|firstTruthy|cond|keys|vals|has|union|minus|inter|add|sub|mul|div|split|join|contains|startsWith|endsWith|prepend|append|not|eq|gt|lt|gte|lte|and|or|json|table|env|use|reify|manifest|runExamples)(?![a-zA-Z0-9_-])",
      "captures": {
        "1": { "name": "support.function.builtin.qlang" }
      }
    },

    "identifier": {
      "comment": "User-defined operand calls and conduit references.",
      "name": "entity.name.function.qlang",
      "match": "[@_a-zA-Z][a-zA-Z0-9_-]*"
    },

    "punctuation": {
      "comment": "Structural brackets — enables rainbow bracket themes and punctuation-aware themes.",
      "patterns": [
        { "name": "punctuation.section.parens.begin.qlang",    "match": "\\(" },
        { "name": "punctuation.section.parens.end.qlang",      "match": "\\)" },
        { "name": "punctuation.section.brackets.begin.qlang",  "match": "\\[" },
        { "name": "punctuation.section.brackets.end.qlang",    "match": "\\]" },
        { "name": "punctuation.section.braces.begin.qlang",    "match": "(?<!#)\\{" },
        { "name": "punctuation.section.braces.end.qlang",      "match": "\\}" },
        { "name": "punctuation.separator.comma.qlang",         "match": "," }
      ]
    }
  }
}
