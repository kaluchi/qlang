{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "markdown.qlang.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [{ "include": "#fenced-code-block" }],
  "repository": {
    "fenced-code-block": {
      "begin": "(^|\\G)(\\s*)(```+)\\s*(qlang)\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language" }
      },
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "contentName": "meta.embedded.block.qlang",
      "patterns": [{ "include": "source.qlang" }]
    }
  }
}
